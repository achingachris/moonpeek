//
//  Secrets.swift.example
//  MoonPeek
//
//  Template for the real (gitignored) Secrets.swift.
//
//  Setup:
//    1. cp Secrets.swift.example Secrets.swift
//    2. Fill in the placeholder values below with your Linode credentials.
//    3. In Xcode, drag Secrets.swift into the MoonPeek target so it builds.
//
//  Secrets.swift is excluded by .gitignore so the real values never reach git.
//

import Foundation

enum Secrets {
    /// Linode Object Storage access key for the Artemis bucket.
    static let linodeAccessKey = "<YOUR_LINODE_ACCESS_KEY>"

    /// Linode Object Storage secret key. Treat as sensitive.
    static let linodeSecretKey = "<YOUR_LINODE_SECRET_KEY>"
}
